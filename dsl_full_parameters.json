{
  "dsl_version": "1.2",
  "description": "Full parameter catalog for lake-ingestion DSL. Mapping is implicit via data_processing.rules[*].rule_input and rule_output.",
  "template": {
    "model_selection": {
      "model_code": "UM_4G_HW_COUNTER"
    },
    "global_setting": {
      "index": "mapping_step_001",
      "data_sources": {
        "tables": [
          {
            "source_id": "table_a",
            "source_name": "counter_a.csv",
            "source_type": "file",
            "file_path": "/uploads/counter_a.csv",
            "columns": [
              { "name": "SITE_ID", "type": "string", "sample_value": "225" },
              { "name": "DATE_TIME", "type": "datetime", "sample_value": "2026-03-01 11:20:30" }
            ]
          },
          {
            "source_id": "table_b",
            "source_name": "counter_b.csv",
            "source_type": "file",
            "file_path": "/uploads/counter_b.csv",
            "columns": [
              { "name": "SITE_ID", "type": "string", "sample_value": "225" },
              { "name": "FIELD0001", "type": "decimal", "sample_value": "36.25" }
            ]
          }
        ]
      },
      "join_config": {
        "index": "join_tables",
        "rule_input": [
          { "source_table": "table_a", "key_columns": ["SITE_ID"] },
          { "source_table": "table_b", "key_columns": ["SITE_ID"] }
        ],
        "rule_output": { "output_table": "table_joined" },
        "rule": {
          "ability_name": "join",
          "params": [
            { "param_name": "join_type", "param_type": "enum", "param_value": "left" },
            { "param_name": "left_table", "param_type": "string", "param_value": "$rule_input[0].source_table" },
            { "param_name": "right_table", "param_type": "string", "param_value": "$rule_input[1].source_table" },
            { "param_name": "left_key", "param_type": "string", "param_value": "$rule_input[0].key_columns[0]" },
            { "param_name": "right_key", "param_type": "string", "param_value": "$rule_input[1].key_columns[0]" },
            { "param_name": "left_keys", "param_type": "array", "param_value": "$rule_input[0].key_columns" },
            { "param_name": "right_keys", "param_type": "array", "param_value": "$rule_input[1].key_columns" },
            { "param_name": "suffix", "param_type": "string", "param_value": "_right" },
            { "param_name": "on_no_match", "param_type": "enum", "param_value": "null" }
          ]
        }
      },
      "deduplicate": {
        "index": "deduplicate_data",
        "rule_input": [
          { "source_table": "table_mapped", "key_columns": ["SITE_ID"] }
        ],
        "rule_output": { "output_table": "table_mapped" },
        "rule": {
          "ability_name": "deduplicate",
          "params": [
            { "param_name": "dedup_keys", "param_type": "string", "param_value": "$rule_input[0].key_columns[0]" },
            { "param_name": "dedup_keys", "param_type": "array", "param_value": "$rule_input[0].key_columns" },
            { "param_name": "keep", "param_type": "enum", "param_value": "first" }
          ]
        }
      }
    },
    "data_processing": {
      "source_table": "raw_sources",
      "rules": [
        {
          "index": "rule_site_id_1",
          "rule_input": [
            { "source_table": "table_a", "key_columns": ["SITE_ID"] }
          ],
          "rule_output": {
            "output_table": "UM_4G_HW_COUNTER",
            "output_column": "SITE_ID"
          }
        },
        {
          "index": "rule_time_date_2",
          "rule_input": [
            { "source_table": "table_a", "key_columns": ["DATE_TIME"] }
          ],
          "rule_output": {
            "output_table": "UM_4G_HW_COUNTER",
            "output_column": "TIME_DATE"
          },
          "filter": [
            { "param_name": "operator", "param_type": "enum", "param_value": "not_equal" },
            { "param_name": "column", "param_type": "string", "param_value": "$rule_input[0].key_columns[0]" },
            { "param_name": "value", "param_type": "string", "param_value": "" },
            { "param_name": "logic", "param_type": "enum", "param_value": "AND" },
            { "param_name": "conditions", "param_type": "array", "param_value": [{ "operator": "greater_than", "value": "0" }] },
            { "param_name": "formula", "param_type": "string", "param_value": "=value>0" }
          ],
          "rule": {
            "ability_name": "transform",
            "params": [
              { "param_name": "transform_type", "param_type": "enum", "param_value": "format_datetime" },
              { "param_name": "column", "param_type": "string", "param_value": "$rule_output.output_column" },
              { "param_name": "value", "param_type": "string", "param_value": "" },
              { "param_name": "delimiter", "param_type": "string", "param_value": "" },
              { "param_name": "search_value", "param_type": "string", "param_value": "/" },
              { "param_name": "replace_value", "param_type": "string", "param_value": "-" },
              { "param_name": "formula", "param_type": "string", "param_value": "=value" },
              { "param_name": "input_format", "param_type": "string", "param_value": "yyyy.M.d H:mm:ss" },
              { "param_name": "output_format", "param_type": "string", "param_value": "yyyy-MM-dd" },
              { "param_name": "precision", "param_type": "integer", "param_value": 3 },
              { "param_name": "steps", "param_type": "array", "param_value": [] }
            ]
          },
          "sort": [
            { "param_name": "directions", "param_type": "enum", "param_value": "asc" },
            { "param_name": "nulls_position", "param_type": "enum", "param_value": "last" }
          ]
        },
        {
          "index": "rule_common10_3",
          "rule_input": [
            { "source_table": "", "key_columns": [] }
          ],
          "rule_output": {
            "output_table": "UM_4G_HW_COUNTER",
            "output_column": "COMMON10"
          }
        }
      ]
    },
    "write_config": {
      "index": "rule_write_final",
      "rule_input": [
        { "source_table": "UM_4G_HW_COUNTER", "key_columns": [] }
      ],
      "rule_output": {
        "output_table": "UM_4G_HW_COUNTER"
      },
      "rule": {
        "ability_name": "write",
        "params": [
          { "param_name": "format", "param_type": "enum", "param_value": "parquet" },
          { "param_name": "output_path", "param_type": "string", "param_value": "/data/output/UM_4G_HW_COUNTER/" },
          { "param_name": "partition_by", "param_type": "array", "param_value": ["PARTITION_FIELD"] },
          { "param_name": "overwrite", "param_type": "boolean", "param_value": false },
          { "param_name": "write_mode", "param_type": "enum", "param_value": "append" },
          { "param_name": "deduplication", "param_type": "boolean", "param_value": false },
          { "param_name": "dedup_fields", "param_type": "array", "param_value": [] },
          { "param_name": "conflict_strategy", "param_type": "enum", "param_value": "keep_old" }
        ]
      }
    }
  },
  "enum_catalog": {
    "join_type": ["inner", "left", "full"],
    "dedup_keep": ["first", "last", "any"],
    "filter_operator": ["equal", "not_equal", "contains", "is_empty", "is_not_empty", "greater_than", "less_than", "compound", "formula"],
    "transform_type": ["to_upper", "to_lower", "trim", "format_datetime", "extract_year", "extract_month", "extract_time", "format_time", "calc_week", "calc_weekday", "to_number", "remove_thousand_sep", "remove_percent", "set_value", "concat", "replace", "formula", "chain"],
    "write_mode": ["append", "replace"],
    "conflict_strategy": ["keep_old", "overwrite"],
    "file_format": ["parquet", "csv", "json"]
  },
  "ability_catalog": {
    "join": ["join_type", "left_table", "right_table", "left_key", "right_key", "left_keys", "right_keys", "suffix", "on_no_match"],
    "deduplicate": ["dedup_keys", "keep"],
    "transform": ["transform_type", "column", "value", "delimiter", "search_value", "replace_value", "formula", "input_format", "output_format", "precision", "steps"],
    "conditional_transform": ["rules"],
    "if_branch": ["condition"],
    "sort": ["column", "directions", "nulls_position"],
    "write": ["format", "output_path", "partition_by", "overwrite", "write_mode", "deduplication", "dedup_fields", "conflict_strategy"]
  }
}
