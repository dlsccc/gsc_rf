# API base URL for axios client
VITE_API_BASE_URL=/api

# Keep false to use built-in mock model data.
# Switch to true when backend model APIs are ready.
VITE_ENABLE_MODEL_API=false

# DSL publish endpoint (will be appended to VITE_API_BASE_URL when relative path is used)
VITE_PIPELINE_PUBLISH_ENDPOINT=/pipeline/publish
